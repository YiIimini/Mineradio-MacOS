{
  "name": "mineradio-macos",
  "productName": "Mineradio-MacOS",
  "version": "1.4.0",
  "description": "\u6c89\u6d78\u5f0f\u97f3\u4e50\u64ad\u653e\u5668\uff0c\u878d\u5408\u5929\u6c14\u7535\u53f0\u3001\u6b4c\u8bcd\u821e\u53f0\u3001\u7c92\u5b50\u89c6\u89c9\u548c 3D \u6b4c\u5355\u67b6\u3002",
  "author": "YiIimini",
  "main": "desktop/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "test": "node --test tests/*.test.js",
    "build:mac": "electron-builder --mac dmg zip",
    "build:mac:dir": "electron-builder --mac dir"
  },
  "build": {
    "appId": "com.mineradio.desktop",
    "productName": "Mineradio-MacOS",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "afterPack": "build/after-pack.js",
    "files": [
      "desktop/**/*",
      "public/**/*",
      "build/**/*",
      "server.js",
      "server/**/*",
      "dj-analyzer.js",
      "bilibili-api.js",
      "kugou-api.js",
      "package.json",
      "!public/index.*.html",
      "public/index.html"
    ],
    "asar": true,
    "publish": [
      {
        "provider": "github",
        "owner": "YiIimini",
        "repo": "Mineradio-MacOS"
      }
    ],
    "asarUnpack": [
      "desktop/macos-lyrics-helper",
      "desktop/macos-media-helper"
    ],
    "dmg": {
      "background": "build/dmg-background.png",
      "window": {
        "width": 658,
        "height": 498
      },
      "iconSize": 76,
      "iconTextSize": 12,
      "contents": [
        { "x": 164, "y": 210, "type": "file" },
        { "x": 418, "y": 210, "type": "link", "path": "/Applications" }
      ]
    },
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.music",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "artifactName": "Mineradio-MacOS-${version}-mac-${arch}.${ext}",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    }
  },
  "mineradio": {
    "update": {
      "provider": "github",
      "owner": "YiIimini",
      "repo": "Mineradio-MacOS",
      "preview": true,
      "preferMirrors": true,
      "mirrors": [
        "https://gh.llkk.cc/",
        "https://ghfast.top/",
        "https://gh-proxy.com/"
      ]
    }
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "mpg123-decoder": "^1.0.3",
    "NeteaseCloudMusicApi": "^4.32.0"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^26.15.3"
  }
}